# Optional. Keep empty to use the local extractive answer fallback.
RAG_LLM_API_KEY=
RAG_LLM_BASE_URL=https://api.deepseek.com
RAG_LLM_MODEL=deepseek-chat

# Retrieval defaults
RAG_INDEX_DIR=data/index
RAG_TOP_K=5
RAG_VECTOR_WEIGHT=0.65
RAG_BM25_WEIGHT=0.35

# local: chunks.json + vectors.npy
# external: MySQL + Elasticsearch + MinIO
RAG_STORAGE_BACKEND=local

# Docker storage defaults
RAG_DATABASE_URL=mysql+pymysql://rag:rag_password@mysql:3306/rag_kit?charset=utf8mb4
RAG_ELASTICSEARCH_URL=http://elasticsearch:9200
RAG_ELASTICSEARCH_INDEX=rag_chunks
RAG_MINIO_ENDPOINT=minio:9000
RAG_MINIO_ACCESS_KEY=rag_minio
RAG_MINIO_SECRET_KEY=rag_minio_password
RAG_MINIO_BUCKET=rag-documents
RAG_MINIO_SECURE=false
